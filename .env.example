# Copy this file to .env.local, then fill in your own keys.
# Do not send these keys in chat.

# Required for real Doubao / Volcengine Ark calls.
ARK_API_KEY=
ARK_MODEL=
ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3

# Configure at least one search provider.
BING_SEARCH_API_KEY=
SERPAPI_KEY=

# Local server port.
PORT=8790

# Optional protection for public deployment.
ACCESS_CODE=
RATE_LIMIT_PER_HOUR=30
CACHE_TTL_HOURS=24
