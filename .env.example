# Copy this file to .env.local, then fill in your own keys.
# Do not send these keys in chat.

# Preferred: any OpenAI-compatible model provider.
AI_PROVIDER_NAME=
AI_API_KEY=
AI_MODEL=
AI_BASE_URL=
AI_FALLBACK_MODELS=

# Optional domestic providers. Configure one of these when Doubao quota is exhausted.
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-v4-flash
DEEPSEEK_BASE_URL=https://api.deepseek.com

DASHSCOPE_API_KEY=
QWEN_MODEL=qwen-turbo-latest
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

MOONSHOT_API_KEY=
MOONSHOT_MODEL=kimi-k2-0711-preview
MOONSHOT_BASE_URL=https://api.moonshot.cn/v1

# Legacy: Doubao / Volcengine Ark calls.
ARK_API_KEY=
ARK_MODEL=
ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3

# Configure at least one search provider.
BING_SEARCH_API_KEY=
SERPAPI_KEY=

# Local server port.
PORT=8790

# Optional protection for public deployment.
ACCESS_CODE=
RATE_LIMIT_PER_HOUR=30
CACHE_TTL_HOURS=24
